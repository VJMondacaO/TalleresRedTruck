# Cloudinary
# Dejar vacio para servir assets desde /public (modo desarrollo).

# --- Cliente (se incluyen en el bundle): solo el cloud_name es publico ---
PUBLIC_CLOUDINARY_CLOUD_NAME=
# Opcional: prefijo de carpeta dentro de Cloudinary (sin / inicial ni final).
PUBLIC_CLOUDINARY_FOLDER=

# --- Server-only (NO se exponen al cliente, sin prefijo PUBLIC_) ---
# Solo se usan desde scripts/ (upload, signed URLs, admin API).
# Opcion A: un solo string con todo (formato oficial Cloudinary)
# cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
# Opcion B: key y secret por separado
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
