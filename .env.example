# Cloudinary
# Dejar vacio para servir assets desde /public (modo desarrollo).
# Setear con el nombre del cloud para servir desde el CDN.
PUBLIC_CLOUDINARY_CLOUD_NAME=

# Opcional: prefijo de carpeta dentro de Cloudinary (sin / inicial ni final).
# Ej: "talleresredtruck" si todos los assets viven bajo esa carpeta.
PUBLIC_CLOUDINARY_FOLDER=
