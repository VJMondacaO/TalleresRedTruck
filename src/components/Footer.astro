---
import { site, whatsappLink } from '../config/site';

const year = new Date().getFullYear();

const cols = [
  {
    title: 'Servicios',
    links: [
      { label: 'Mantención preventiva', href: '#servicios' },
      { label: 'Diagnóstico electrónico', href: '#servicios' },
      { label: 'Reparación de motor', href: '#servicios' },
      { label: 'Sistema eléctrico', href: '#servicios' },
    ],
  },
  {
    title: 'Empresa',
    links: [
      { label: 'Cobertura', href: '#cobertura' },
      { label: 'Especialización Mercedes-Benz', href: '#mercedes' },
      { label: 'Instagram', href: '#instagram' },
      { label: 'Contacto', href: '#contacto' },
    ],
  },
];
---

<footer class="relative bg-black/85 text-white backdrop-blur-sm border-t border-white/10 overflow-hidden">
  <img
    src="/logo-slow.gif"
    alt=""
    aria-hidden="true"
    class="pointer-events-none select-none absolute bottom-0 left-0 w-[260px] sm:w-[340px] lg:w-[420px]"
    style="mix-blend-mode: screen; filter: brightness(1.2) contrast(1.15) saturate(1.05);"
  />
  <div class="container-x py-16 relative">
    <div class="grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-5">
        <a href="#top" class="inline-flex items-center gap-3 group" aria-label={site.name}>
          <span class="inline-flex h-14 w-14 items-center justify-center overflow-visible -my-2">
            <img
              src="/logo-slow.gif"
              alt=""
              class="h-full w-full object-contain"
              style="mix-blend-mode: screen; filter: brightness(1.25) contrast(1.2) saturate(1.1);"
            />
          </span>
          <span class="font-extrabold text-lg">
            Talleres <span class="text-brand-red">Red Truck</span>
          </span>
        </a>
        <p class="mt-4 text-sm text-white/70 max-w-md">
          Taller mecánico especializado en camiones Mercedes-Benz, ubicado en San Rafael, Región
          del Maule. Recibimos camiones de trabajo desde distintas zonas de Chile.
        </p>

        <div class="mt-6 flex items-center gap-3">
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-white/15 hover:border-brand-red hover:bg-brand-red/10 hover:text-brand-red transition"
          >
            <i class="pi pi-instagram" aria-hidden="true"></i>
          </a>
          <a
            href={site.social.facebook}
            target="_blank"
            rel="noopener"
            aria-label="Facebook"
            class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-white/15 hover:border-brand-red hover:bg-brand-red/10 hover:text-brand-red transition"
          >
            <i class="pi pi-facebook" aria-hidden="true"></i>
          </a>
          <a
            href={whatsappLink()}
            target="_blank"
            rel="noopener"
            aria-label="WhatsApp"
            class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-white/15 hover:border-brand-red hover:bg-brand-red/10 hover:text-brand-red transition"
          >
            <i class="pi pi-whatsapp" aria-hidden="true"></i>
          </a>
        </div>
      </div>

      {cols.map((c) => (
        <div class="lg:col-span-2">
          <p class="text-xs uppercase tracking-wider font-semibold text-white/60">{c.title}</p>
          <ul class="mt-4 space-y-2">
            {c.links.map((l) => (
              <li>
                <a href={l.href} class="text-sm text-white/80 hover:text-white">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="lg:col-span-3">
        <p class="text-xs uppercase tracking-wider font-semibold text-white/60">Contacto</p>
        <ul class="mt-4 space-y-3 text-sm text-white/80">
          <li class="flex gap-2">
            <i class="pi pi-whatsapp text-brand-red mt-0.5" aria-hidden="true"></i>
            <a href={whatsappLink()} target="_blank" rel="noopener" class="hover:text-white">
              {site.whatsapp.display}
            </a>
          </li>
          <li class="flex gap-2">
            <i class="pi pi-phone text-brand-red mt-0.5" aria-hidden="true"></i>
            <a href={`tel:${site.phone}`} class="hover:text-white">{site.phone}</a>
          </li>
          <li class="flex gap-2">
            <i class="pi pi-envelope text-brand-red mt-0.5" aria-hidden="true"></i>
            <a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a>
          </li>
          <li class="flex gap-2">
            <i class="pi pi-map-marker text-brand-red mt-0.5" aria-hidden="true"></i>
            <span>{site.address}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-8 border-t border-white/10 flex flex-wrap items-center justify-between gap-4 text-xs text-white/60">
      <p>© {year} {site.name}. Todos los derechos reservados.</p>
      <p>Mercedes-Benz® es una marca registrada de sus respectivos propietarios. Talleres Red Truck es un taller independiente, no oficial.</p>
    </div>
  </div>
</footer>
