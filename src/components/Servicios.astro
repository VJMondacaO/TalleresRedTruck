---
const servicios = [
  {
    icon: 'pi-wrench',
    title: 'Mantención preventiva',
    desc: 'Pautas oficiales Mercedes-Benz. Cambios de aceite, filtros, frenos y revisiones programadas.',
  },
  {
    icon: 'pi-microchip',
    title: 'Diagnóstico electrónico',
    desc: 'Equipos Xentry / Star Diagnosis para detectar fallas en módulos ECU, ABS y transmisión.',
  },
  {
    icon: 'pi-cog',
    title: 'Reparación de motor',
    desc: 'Reparaciones mayores y menores: inyección, turbo, sistema de refrigeración y embrague.',
  },
  {
    icon: 'pi-bolt',
    title: 'Sistema eléctrico',
    desc: 'Diagnóstico y reparación de sistema eléctrico, alternadores, partidas y baterías.',
  },
  {
    icon: 'pi-box',
    title: 'Repuestos originales',
    desc: 'Disponibilidad de repuestos Mercedes-Benz originales y alternativos certificados.',
  },
  {
    icon: 'pi-clock',
    title: 'Atención 24/7',
    desc: 'Asistencia en ruta y emergencias todos los días del año, en todo el país.',
  },
];
---

<section id="servicios" class="section bg-white">
  <div class="container-x">
    <div class="max-w-2xl">
      <p class="eyebrow">Servicios</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-brand-dark">
        Todo lo que tu camión necesita, en un solo lugar.
      </h2>
      <p class="mt-4 text-brand-dark/70">
        Servicio técnico integral para camiones Mercedes-Benz. Diagnóstico, repuestos y mantención
        con estándares de marca.
      </p>
    </div>

    <ul class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {servicios.map((s) => (
        <li class="group rounded-xl border border-brand-dark/10 bg-white p-7 hover:border-brand-dark/30 hover:shadow-soft transition">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-brand-dark text-white group-hover:bg-brand-red transition-colors">
            <i class={`pi ${s.icon} text-xl`} aria-hidden="true"></i>
          </span>
          <h3 class="mt-5 text-lg font-bold text-brand-dark">{s.title}</h3>
          <p class="mt-2 text-sm text-brand-dark/70 leading-relaxed">{s.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
