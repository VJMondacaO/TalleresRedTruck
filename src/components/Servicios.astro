---
const servicios = [
  {
    icon: 'pi-microchip',
    title: 'Scanner y diagnóstico electrónico',
    desc: 'Lectura de fallas y revisión de módulos para detectar problemas de motor, transmisión, ABS, sensores y sistemas eléctricos.',
  },
  {
    icon: 'pi-bolt',
    title: 'Electrónica diésel',
    desc: 'Diagnóstico y reparación de fallas electrónicas en sistemas diésel para camiones pesados y semi pesados.',
  },
  {
    icon: 'pi-cog',
    title: 'Reparación de camiones',
    desc: 'Trabajos mecánicos en motor, inyección, turbo, refrigeración, embrague, frenos y componentes asociados.',
  },
  {
    icon: 'pi-wrench',
    title: 'Mantención preventiva',
    desc: 'Cambios de aceite, filtros, frenos, revisión general y trabajos programados según el uso real del camión.',
  },
  {
    icon: 'pi-truck',
    title: 'Grúas para camiones',
    desc: 'Coordinación de grúas para camiones pesados y semi pesados, según disponibilidad y condiciones del traslado.',
  },
  {
    icon: 'pi-briefcase',
    title: 'Transporte de maquinaria',
    desc: 'Apoyo para traslado de maquinaria y arriendo de camionetas para operaciones que necesitan continuidad en terreno.',
  },
];
---

<section id="servicios" class="section bg-transparent text-white">
  <div class="container-x">
    <div class="max-w-2xl">
      <p class="eyebrow">Servicios</p>
      <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-[1.05]">
        Soluciones para camiones
        <span class="text-brand-red">que necesitan volver a la ruta.</span>
      </h2>
      <p class="mt-5 text-white/65 leading-relaxed">
        Atendemos camiones pesados y semi pesados con scanner, electrónica diésel, mantenciones,
        reparaciones y apoyo operativo para traslado de camiones o maquinaria.
      </p>
    </div>

    <ul class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {servicios.map((s) => (
        <li class="group card-dark p-7 relative overflow-hidden">
          <div class="absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-brand-red/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-white/[0.04] border border-white/10 text-brand-red group-hover:bg-brand-red group-hover:text-white group-hover:border-brand-red transition-all duration-300">
            <i class={`pi ${s.icon} text-xl`} aria-hidden="true"></i>
          </span>
          <h3 class="mt-5 text-lg font-bold text-white">{s.title}</h3>
          <p class="mt-2 text-sm text-white/60 leading-relaxed">{s.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
