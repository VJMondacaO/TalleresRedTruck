---
import { site, whatsappLink } from '../config/site';

const links = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Cobertura', href: '#cobertura' },
  { label: 'Especialidades', href: '#mercedes' },
  { label: 'Instagram', href: '#instagram' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header class="sticky top-0 z-40 bg-black/70 backdrop-blur-md border-b border-white/10">
  <nav class="container-x flex items-center justify-between h-16 lg:h-20" aria-label="Principal">
    <a href="#top" class="flex items-center gap-3 group" aria-label={site.name}>
      <span class="inline-flex h-16 w-16 lg:h-20 lg:w-20 items-center justify-center overflow-visible -my-3">
        <img src="/icono.png" alt="" class="h-full w-full object-contain" />
      </span>
      <span class="font-extrabold text-white tracking-tight text-lg">
        Talleres <span class="text-brand-red">Red Truck</span>
      </span>
    </a>

    <ul class="hidden lg:flex items-center gap-8">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="relative text-sm font-medium text-white/70 hover:text-white transition-colors after:absolute after:left-0 after:-bottom-1 after:h-px after:w-0 after:bg-brand-red after:transition-all hover:after:w-full"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden lg:flex items-center gap-3">
      <a href={whatsappLink()} target="_blank" rel="noopener" class="btn-wtz">
        <i class="pi pi-whatsapp" aria-hidden="true"></i>
        Cotizar por WhatsApp
      </a>
    </div>

    <button
      id="navToggle"
      class="lg:hidden inline-flex items-center justify-center h-10 w-10 rounded-md border border-white/15 text-white hover:bg-white/10 transition"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobileMenu"
    >
      <i class="pi pi-bars text-lg" aria-hidden="true"></i>
    </button>
  </nav>

  <div id="mobileMenu" class="lg:hidden hidden border-t border-white/10 bg-black/95 backdrop-blur-md">
    <ul class="container-x py-4 flex flex-col gap-1">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="block py-3 text-base font-medium text-white/85 hover:text-white"
            data-mobile-link
          >
            {l.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href={whatsappLink()} target="_blank" rel="noopener" class="btn-wtz w-full">
          <i class="pi pi-whatsapp" aria-hidden="true"></i>
          Cotizar por WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('mobileMenu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });
    menu.querySelectorAll('[data-mobile-link]').forEach((l) => {
      l.addEventListener('click', () => {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
