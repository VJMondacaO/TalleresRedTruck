---
import { cdn } from '../lib/cdn';

const frameCount = 59;
// Generamos las URLs en build-time (no en runtime) para que cdn() resuelva
// con import.meta.env durante el SSG.
const avifFrames = Array.from({ length: frameCount }, (_, i) =>
  cdn(`frames/motor/frame-${String(i + 1).padStart(4, '0')}.avif`)
);
const webpFrames = Array.from({ length: frameCount }, (_, i) =>
  cdn(`frames/motor/frame-${String(i + 1).padStart(4, '0')}.webp`)
);
---

<section
  class="rt-frame-stage relative isolate bg-black text-white"
  data-frame-count={frameCount}
  data-frames-avif={JSON.stringify(avifFrames)}
  data-frames-webp={JSON.stringify(webpFrames)}
>
  <div class="sticky top-0 h-screen overflow-hidden" aria-hidden="true">
    <canvas class="rt-frame-canvas absolute inset-0 h-full w-full"></canvas>
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/20 to-black/85"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/25 to-black/60"></div>
    <div class="absolute inset-0 bg-grid-faint opacity-60" style="background-size: 64px 64px;"></div>
  </div>

  <div class="rt-frame-content relative">
    <slot />
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const stage = document.querySelector<HTMLElement>('.rt-frame-stage');
  const canvas = document.querySelector<HTMLCanvasElement>('.rt-frame-canvas');
  const ctx = canvas?.getContext('2d');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (stage && canvas && ctx) {
    const frameCount = Number(stage.dataset.frameCount || 1);
    const avifFrames = JSON.parse(stage.dataset.framesAvif || '[]') as string[];
    const webpFrames = JSON.parse(stage.dataset.framesWebp || '[]') as string[];

    // Feature detect AVIF una sola vez.
    const supportsAvif = await (async () => {
      try {
        const probe = new Image();
        probe.src =
          'data:image/avif;base64,';
        await probe.decode();
        return true;
      } catch {
        return false;
      }
    })();

    const frameUrls = supportsAvif ? avifFrames : webpFrames;
    const images: HTMLImageElement[] = [];
    const loadingFrames = new Set<number>();
    let currentFrame = 0;

    const resizeCanvas = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const width = Math.round(canvas.clientWidth * dpr);
      const height = Math.round(canvas.clientHeight * dpr);

      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;
        drawFrame(currentFrame);
      }
    };

    const drawFrame = (index: number) => {
      const image = images[index];
      if (!image?.complete || !image.naturalWidth) return;

      currentFrame = index;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const scale = Math.max(canvas.width / image.naturalWidth, canvas.height / image.naturalHeight);
      const width = image.naturalWidth * scale;
      const height = image.naturalHeight * scale;
      const x = (canvas.width - width) / 2;
      const y = (canvas.height - height) / 2;

      ctx.drawImage(image, x, y, width, height);
    };

    const loadFrame = (index: number) => {
      if (images[index] || loadingFrames.has(index) || !frameUrls[index]) return;

      loadingFrames.add(index);
      const image = new Image();
      image.decoding = 'async';
      image.src = frameUrls[index];
      image.onload = () => {
        loadingFrames.delete(index);
        if (index === currentFrame) drawFrame(index);
      };
      image.onerror = () => loadingFrames.delete(index);
      images[index] = image;
    };

    const preloadFrames = () => {
      let index = 1;

      const loadChunk = () => {
        for (let count = 0; count < 6 && index < frameCount; count += 1) {
          loadFrame(index);
          index += 1;
        }

        if (index < frameCount) {
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(loadChunk);
          } else {
            window.setTimeout(loadChunk, 80);
          }
        }
      };

      loadChunk();
    };

    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    // Diferimos la descarga hasta que el stage este a 1.5 viewports.
    const startLoading = () => {
      loadFrame(0);
      preloadFrames();

      if (!reduceMotion) {
        ScrollTrigger.create({
          trigger: stage,
          start: 'top top',
          end: 'bottom bottom',
          scrub: true,
          onUpdate: (self) => {
            const nextFrame = Math.min(frameCount - 1, Math.round(self.progress * (frameCount - 1)));
            if (nextFrame !== currentFrame) {
              loadFrame(nextFrame);
              drawFrame(nextFrame);
            }
          },
        });
      }
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            io.disconnect();
            startLoading();
          }
        },
        { rootMargin: '150% 0px 150% 0px' }
      );
      io.observe(stage);
    } else {
      startLoading();
    }
  }
</script>
