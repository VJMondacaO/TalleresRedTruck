---
import { whatsappLink } from '../config/site';

const bullets = [
  {
    icon: 'pi-users',
    title: 'Técnicos con experiencia en MB',
    desc: 'Equipo dedicado a camiones Mercedes-Benz: conocen los modelos, los problemas comunes y los detalles electrónicos.',
  },
  {
    icon: 'pi-microchip',
    title: 'Diagnóstico Xentry',
    desc: 'Lectura de fallas, codificaciones y programación de módulos con el software de la marca.',
  },
  {
    icon: 'pi-box',
    title: 'Repuestos originales',
    desc: 'Trabajamos con repuestos Mercedes-Benz originales. Alternativos solo cuando el cliente lo prefiere.',
  },
  {
    icon: 'pi-shield',
    title: 'Garantía por escrito',
    desc: 'Cada servicio queda con garantía detallada en la orden de trabajo.',
  },
];

const modelos = ['Actros', 'Axor', 'Atego', 'Accelo', 'Arocs', 'Atron'];
---

<section id="mercedes" class="section bg-transparent text-white">
  <div class="container-x">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-6 order-2 lg:order-1">
        <p class="eyebrow">Especialización</p>
        <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-[1.05]">
          Trabajamos solo con <span class="text-brand-red">Mercedes-Benz.</span>
        </h2>
        <p class="mt-5 text-white/65 leading-relaxed">
          No somos un taller generalista que también atiende camiones. Nos dedicamos a camiones
          Mercedes-Benz: ese foco nos permite resolver más rápido y con menos pruebas.
        </p>

        <ul class="mt-10 grid sm:grid-cols-2 gap-5">
          {bullets.map((b) => (
            <li class="group flex gap-4">
              <span class="flex-shrink-0 inline-flex h-11 w-11 items-center justify-center rounded-md border border-white/10 bg-white/[0.04] text-brand-red group-hover:bg-brand-red group-hover:text-white group-hover:border-brand-red transition-all">
                <i class={`pi ${b.icon}`} aria-hidden="true"></i>
              </span>
              <div>
                <p class="font-bold text-white">{b.title}</p>
                <p class="mt-1 text-sm text-white/60 leading-relaxed">{b.desc}</p>
              </div>
            </li>
          ))}
        </ul>

        <div class="mt-10">
          <a
            href={whatsappLink('Hola, necesito servicio para mi Mercedes-Benz.')}
            target="_blank"
            rel="noopener"
            class="btn-wtz"
          >
            <i class="pi pi-whatsapp" aria-hidden="true"></i>
            Consultar por mi camión
          </a>
        </div>
      </div>

      <div class="lg:col-span-6 order-1 lg:order-2">
        <div class="relative">
          <div class="absolute -inset-px rounded-2xl bg-gradient-to-br from-brand-red/40 via-transparent to-transparent blur opacity-60"></div>
          <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-soft">
            <img
              src="https://placehold.co/900x700/0A0A0A/DC2626/png?text=Mercedes-Benz+Actros&font=inter"
              alt="Camión Mercedes-Benz Actros en mantención"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
          </div>

          <div class="relative mt-5 rounded-xl border border-white/10 bg-black/50 p-5 backdrop-blur-sm">
            <p class="text-xs uppercase tracking-[0.22em] font-semibold text-brand-red">
              Modelos que atendemos
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {modelos.map((m) => (
                <li class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-sm font-semibold text-white hover:border-brand-red/50 hover:bg-brand-red/10 transition-colors">
                  {m}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
