---
import { Image } from 'astro:assets';
import { whatsappLink } from '../config/site';
import actrosImage from '../assets/especializacion/actros.webp';

const bullets = [
  {
    icon: 'pi-users',
    title: 'Ingeniería y experiencia en terreno',
    desc: 'Formación en maquinaria, vehículos automotrices y sistemas electrónicos aplicada a trabajo pesado.',
  },
  {
    icon: 'pi-microchip',
    title: 'Scanner y electrónica diésel',
    desc: 'Combinamos lectura electrónica, revisión mecánica y experiencia práctica para llegar al origen de la falla.',
  },
  {
    icon: 'pi-box',
    title: 'Especialidad Mercedes-Benz',
    desc: 'Mercedes-Benz es nuestra especialidad más fuerte, con conocimiento de modelos, sistemas y fallas frecuentes.',
  },
  {
    icon: 'pi-shield',
    title: 'Trabajo multimarca',
    desc: 'También atendemos Volvo, Scania, camiones americanos, chinos, pesados y semi pesados.',
  },
];

const marcas = ['Mercedes-Benz', 'Volvo', 'Scania', 'Americanos', 'Chinos', 'Camiones pesados', 'Semi pesados'];
---

<section id="mercedes" class="section bg-transparent text-white">
  <div class="container-x">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-6 order-2 lg:order-1">
        <p class="eyebrow">Especialización</p>
        <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-[1.05]">
          Especialistas en Mercedes-Benz.
          <span class="text-brand-red">Trabajamos multimarca.</span>
        </h2>
        <p class="mt-5 text-white/65 leading-relaxed">
          Red Truck combina ingeniería en maquinaria, vehículos automotrices y sistemas electrónicos
          con años de experiencia en camiones pesados y semi pesados. Mercedes-Benz es nuestra
          especialidad principal, pero también trabajamos Volvo, Scania, americanos y chinos.
        </p>

        <ul class="mt-10 grid sm:grid-cols-2 gap-5">
          {bullets.map((b) => (
            <li class="group flex gap-4">
              <span class="flex-shrink-0 inline-flex h-11 w-11 items-center justify-center rounded-md border border-white/10 bg-white/[0.04] text-brand-red group-hover:bg-brand-red group-hover:text-white group-hover:border-brand-red transition-all">
                <i class={`pi ${b.icon}`} aria-hidden="true"></i>
              </span>
              <div>
                <p class="font-bold text-white">{b.title}</p>
                <p class="mt-1 text-sm text-white/60 leading-relaxed">{b.desc}</p>
              </div>
            </li>
          ))}
        </ul>

        <div class="mt-10">
          <a
            href={whatsappLink('Hola, necesito coordinar servicio para mi camión o maquinaria.')}
            target="_blank"
            rel="noopener"
            class="btn-wtz"
          >
            <i class="pi pi-whatsapp" aria-hidden="true"></i>
            Consultar por mi camión
          </a>
        </div>
      </div>

      <div class="lg:col-span-6 order-1 lg:order-2">
        <div class="relative">
          <div class="absolute -inset-px rounded-2xl bg-gradient-to-br from-brand-red/40 via-transparent to-transparent blur opacity-60"></div>
          <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-soft">
            <Image
              src={actrosImage}
              alt="Camión pesado en revisión mecánica"
              widths={[480, 720, 900]}
              sizes="(max-width: 1024px) 90vw, 540px"
              formats={['avif', 'webp']}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
          </div>

          <div class="relative mt-5 rounded-xl border border-white/10 bg-black/50 p-5 backdrop-blur-sm">
            <p class="text-xs uppercase tracking-[0.22em] font-semibold text-brand-red">
              Marcas y equipos que atendemos
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {marcas.map((m) => (
                <li class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-sm font-semibold text-white hover:border-brand-red/50 hover:bg-brand-red/10 transition-colors">
                  {m}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
