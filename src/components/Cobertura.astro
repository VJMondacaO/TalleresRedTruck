---
const stats = [
  { value: '16', suffix: 'regiones', label: 'desde donde consultan' },
  { value: 'San Rafael', suffix: '', label: 'base del taller' },
];

const zonas = [
  'Arica y Parinacota',
  'Tarapacá',
  'Antofagasta',
  'Atacama',
  'Coquimbo',
  'Valparaíso',
  'Metropolitana',
  "O'Higgins",
  'Maule',
  'Ñuble',
  'Biobío',
  'Araucanía',
  'Los Ríos',
  'Los Lagos',
  'Aysén',
  'Magallanes',
];
---

<section id="cobertura" class="section bg-transparent text-white relative overflow-hidden">
  <div class="container-x relative">
    <div class="grid lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-5">
        <p class="eyebrow">Cobertura</p>
        <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-[1.05]">
          En San Rafael,
          <span class="text-brand-red">recibimos camiones de todo Chile.</span>
        </h2>
        <p class="mt-5 text-white/65 leading-relaxed">
          Nuestro taller está en San Rafael, Región del Maule. Recibimos camiones pesados, semi
          pesados y maquinaria de transportistas, empresas y faenas de distintas regiones.
          Escríbenos para coordinar diagnóstico, ingreso al taller, grúa o transporte de maquinaria.
        </p>

        <dl class="mt-10 grid grid-cols-2 gap-4 max-w-md">
          {stats.map((s) => (
            <div class="card-dark p-5">
              <dt class="text-xs uppercase tracking-[0.18em] text-white/50">{s.label}</dt>
              <dd class="mt-2 text-3xl font-extrabold text-white">
                {s.value}
                {s.suffix && <span class="ml-1 text-base font-semibold text-brand-red">{s.suffix}</span>}
              </dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-2xl border border-white/10 bg-black/50 p-6 backdrop-blur-sm lg:p-8 relative overflow-hidden">
          <div class="absolute -top-20 -right-20 h-60 w-60 rounded-full bg-brand-red/10 blur-3xl"></div>
          <div class="relative flex items-center justify-between">
            <h3 class="text-lg font-bold text-white">Regiones desde donde podemos coordinar</h3>
            <span class="inline-flex items-center gap-2 text-xs font-semibold text-emerald-400">
              <span class="inline-block h-2 w-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.8)]"></span>
              Coordinación disponible
            </span>
          </div>
          <ul class="relative mt-6 flex flex-wrap gap-2">
            {zonas.map((z) => (
              <li class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-sm text-white/85 hover:border-brand-red/50 hover:bg-brand-red/5 transition-colors">
                <i class="pi pi-map-marker text-brand-red text-xs" aria-hidden="true"></i>
                {z}
              </li>
            ))}
          </ul>
          <p class="relative mt-6 text-sm text-white/55">
            Si vienes desde otra zona, escríbenos con la marca, el modelo, la falla y la ubicación actual del camión o maquinaria.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
