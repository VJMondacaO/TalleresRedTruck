---
const stats = [
  { value: '16', suffix: 'regiones', label: 'donde llegamos' },
  { value: '24/7', suffix: '', label: 'asistencia en ruta' },
];

const zonas = [
  'Arica y Parinacota',
  'Tarapacá',
  'Antofagasta',
  'Atacama',
  'Coquimbo',
  'Valparaíso',
  'Metropolitana',
  "O'Higgins",
  'Maule',
  'Ñuble',
  'Biobío',
  'Araucanía',
  'Los Ríos',
  'Los Lagos',
  'Aysén',
  'Magallanes',
];
---

<section id="cobertura" class="section bg-brand-dark text-white relative overflow-hidden">
  <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-brand-accent/30 blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="container-x relative">
    <div class="grid lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-5">
        <p class="eyebrow !text-brand-red">Cobertura nacional</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold leading-tight">
          De Arica a Punta Arenas.
        </h2>
        <p class="mt-4 text-white/75">
          Atendemos en taller en Santiago y coordinamos servicio en ruta a lo largo del país. Si tu
          camión quedó parado, escríbenos por WhatsApp y vemos cómo llegamos.
        </p>

        <dl class="mt-10 grid grid-cols-2 gap-4 max-w-md">
          {stats.map((s) => (
            <div class="rounded-lg border border-white/10 bg-white/5 p-5">
              <dt class="text-xs uppercase tracking-wider text-white/60">{s.label}</dt>
              <dd class="mt-2 text-3xl font-extrabold">
                {s.value}
                {s.suffix && <span class="ml-1 text-base font-semibold text-white/70">{s.suffix}</span>}
              </dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 lg:p-8">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold">Regiones donde operamos</h3>
            <span class="inline-flex items-center gap-2 text-xs font-semibold text-white/70">
              <span class="inline-block h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
              Servicio activo
            </span>
          </div>
          <ul class="mt-5 flex flex-wrap gap-2">
            {zonas.map((z) => (
              <li class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1.5 text-sm">
                <i class="pi pi-map-marker text-brand-red text-xs" aria-hidden="true"></i>
                {z}
              </li>
            ))}
          </ul>
          <p class="mt-6 text-sm text-white/70">
            ¿No ves tu zona? Coordinamos servicio puntual. Escríbenos y revisamos disponibilidad.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
