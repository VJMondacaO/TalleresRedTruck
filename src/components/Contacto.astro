---
import { site, whatsappLink } from '../config/site';
---

<section id="contacto" class="section bg-transparent text-white">
  <div class="container-x">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <p class="eyebrow">Contacto</p>
        <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-[1.05]">
          Cuéntanos qué necesita
          <span class="text-brand-red">tu camión o maquinaria.</span>
        </h2>
        <p class="mt-5 text-white/65 leading-relaxed">
          Escríbenos con la marca, el modelo, la falla y la ubicación. Te orientamos con claridad
          y coordinamos revisión, reparación, grúa, transporte de maquinaria o arriendo según
          disponibilidad.
        </p>

        <ul class="mt-10 space-y-4">
          <li class="flex items-start gap-4 group">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-md border border-white/10 bg-white/[0.04] text-brand-red flex-shrink-0 group-hover:bg-brand-red group-hover:text-white group-hover:border-brand-red transition-all">
              <i class="pi pi-whatsapp" aria-hidden="true"></i>
            </span>
            <div>
              <p class="text-xs uppercase tracking-[0.22em] font-semibold text-brand-red">WhatsApp</p>
              <a href={whatsappLink()} target="_blank" rel="noopener" class="font-bold text-white hover:text-brand-red transition-colors">
                {site.whatsapp.display}
              </a>
            </div>
          </li>
          <li class="flex items-start gap-4 group">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-md border border-white/10 bg-white/[0.04] text-brand-red flex-shrink-0 group-hover:bg-brand-red group-hover:text-white group-hover:border-brand-red transition-all">
              <i class="pi pi-envelope" aria-hidden="true"></i>
            </span>
            <div>
              <p class="text-xs uppercase tracking-[0.22em] font-semibold text-brand-red">Email</p>
              <a href={`mailto:${site.email}`} class="font-bold text-white hover:text-brand-red transition-colors">
                {site.email}
              </a>
            </div>
          </li>
          <li class="flex items-start gap-4 group">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-md border border-white/10 bg-white/[0.04] text-brand-red flex-shrink-0 group-hover:bg-brand-red group-hover:text-white group-hover:border-brand-red transition-all">
              <i class="pi pi-map-marker" aria-hidden="true"></i>
            </span>
            <div>
              <p class="text-xs uppercase tracking-[0.22em] font-semibold text-brand-red">Dirección</p>
              <p class="font-bold text-white">{site.address}</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="lg:col-span-7">
        <form
          id="contactForm"
          novalidate
          class="relative rounded-2xl border border-white/10 bg-black/50 p-6 shadow-soft backdrop-blur-sm lg:p-8 overflow-hidden"
        >
          <div class="absolute -top-24 -right-24 h-48 w-48 rounded-full bg-brand-red/15 blur-3xl pointer-events-none"></div>
          <div class="relative grid sm:grid-cols-2 gap-5">
            <div class="sm:col-span-2">
              <label for="nombre" class="label-dark">Nombre completo</label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                required
                autocomplete="name"
                class="input-dark mt-2"
              />
            </div>

            <div>
              <label for="telefono" class="label-dark">Teléfono</label>
              <input
                id="telefono"
                name="telefono"
                type="tel"
                required
                autocomplete="tel"
                placeholder="+56 9 ..."
                class="input-dark mt-2"
              />
            </div>

            <div>
              <label for="patente" class="label-dark">
                Patente <span class="text-white/40 font-normal">(opcional)</span>
              </label>
              <input
                id="patente"
                name="patente"
                type="text"
                maxlength="8"
                class="input-dark mt-2 uppercase"
              />
            </div>

            <div class="sm:col-span-2">
              <label for="modelo" class="label-dark">Marca o modelo del camión</label>
              <select
                id="modelo"
                name="modelo"
                class="input-dark mt-2"
              >
                <option value="" class="bg-black">Selecciona un modelo</option>
                <option class="bg-black">Mercedes-Benz</option>
                <option class="bg-black">Volvo</option>
                <option class="bg-black">Scania</option>
                <option class="bg-black">Americano</option>
                <option class="bg-black">Chino</option>
                <option class="bg-black">Otro</option>
              </select>
            </div>

            <div class="sm:col-span-2">
              <label for="mensaje" class="label-dark">¿Qué problema presenta el camión?</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                required
                placeholder="Cuéntanos la falla, síntomas, ubicación actual y si necesitas taller, grúa, transporte o arriendo."
                class="input-dark mt-2"
              ></textarea>
            </div>
          </div>

          <div class="relative mt-7 flex flex-wrap items-center gap-3">
            <button type="submit" class="btn-primary">
              <i class="pi pi-send" aria-hidden="true"></i>
              Enviar consulta
            </button>
            <a href={whatsappLink()} target="_blank" rel="noopener" class="btn-wtz">
              <i class="pi pi-whatsapp" aria-hidden="true"></i>
              Prefiero WhatsApp
            </a>
            <p class="text-xs text-white/50">Respondemos lo antes posible según disponibilidad del taller.</p>
          </div>

          <div
            id="formSuccess"
            class="relative mt-5 hidden rounded-md border border-emerald-500/30 bg-emerald-500/10 p-4 text-sm text-emerald-200"
            role="status"
          >
            <p class="font-semibold">Gracias, recibimos tu consulta.</p>
            <p class="mt-1 text-emerald-200/80">Te contactaremos a la brevedad. Si es urgente, escríbenos también por WhatsApp.</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const ok = document.getElementById('formSuccess');
  if (form && ok) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      ok.classList.remove('hidden');
      form.reset();
      ok.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(() => ok.classList.add('hidden'), 6000);
    });
  }
</script>
