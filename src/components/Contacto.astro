---
import { site, whatsappLink } from '../config/site';
---

<section id="contacto" class="section bg-brand-dark/[0.03]">
  <div class="container-x">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <p class="eyebrow">Contacto</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-brand-dark">
          Cuéntanos qué necesita tu camión.
        </h2>
        <p class="mt-4 text-brand-dark/70">
          Déjanos tus datos y te contactamos a la brevedad. ¿Es urgente? Escríbenos directo por
          WhatsApp y resolvemos en minutos.
        </p>

        <ul class="mt-8 space-y-4">
          <li class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-brand-dark text-white flex-shrink-0">
              <i class="pi pi-whatsapp" aria-hidden="true"></i>
            </span>
            <div>
              <p class="text-xs uppercase tracking-wider font-semibold text-brand-accent">WhatsApp</p>
              <a href={whatsappLink()} target="_blank" rel="noopener" class="font-bold text-brand-dark hover:underline">
                {site.whatsapp.display}
              </a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-brand-dark text-white flex-shrink-0">
              <i class="pi pi-envelope" aria-hidden="true"></i>
            </span>
            <div>
              <p class="text-xs uppercase tracking-wider font-semibold text-brand-accent">Email</p>
              <a href={`mailto:${site.email}`} class="font-bold text-brand-dark hover:underline">
                {site.email}
              </a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-brand-dark text-white flex-shrink-0">
              <i class="pi pi-map-marker" aria-hidden="true"></i>
            </span>
            <div>
              <p class="text-xs uppercase tracking-wider font-semibold text-brand-accent">Dirección</p>
              <p class="font-bold text-brand-dark">{site.address}</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="lg:col-span-7">
        <form
          id="contactForm"
          novalidate
          class="rounded-2xl border border-brand-dark/10 bg-white p-6 lg:p-8 shadow-soft"
        >
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="sm:col-span-2">
              <label for="nombre" class="block text-sm font-semibold text-brand-dark">Nombre completo</label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                required
                autocomplete="name"
                class="mt-2 w-full rounded-md border border-brand-dark/15 bg-white px-3 py-2.5 text-sm focus:border-brand-accent focus:outline-none focus:ring-2 focus:ring-brand-accent/30"
              />
            </div>

            <div>
              <label for="telefono" class="block text-sm font-semibold text-brand-dark">Teléfono</label>
              <input
                id="telefono"
                name="telefono"
                type="tel"
                required
                autocomplete="tel"
                placeholder="+56 9 ..."
                class="mt-2 w-full rounded-md border border-brand-dark/15 bg-white px-3 py-2.5 text-sm focus:border-brand-accent focus:outline-none focus:ring-2 focus:ring-brand-accent/30"
              />
            </div>

            <div>
              <label for="patente" class="block text-sm font-semibold text-brand-dark">
                Patente <span class="text-brand-dark/50 font-normal">(opcional)</span>
              </label>
              <input
                id="patente"
                name="patente"
                type="text"
                maxlength="8"
                class="mt-2 w-full rounded-md border border-brand-dark/15 bg-white px-3 py-2.5 text-sm uppercase focus:border-brand-accent focus:outline-none focus:ring-2 focus:ring-brand-accent/30"
              />
            </div>

            <div class="sm:col-span-2">
              <label for="modelo" class="block text-sm font-semibold text-brand-dark">Modelo Mercedes-Benz</label>
              <select
                id="modelo"
                name="modelo"
                class="mt-2 w-full rounded-md border border-brand-dark/15 bg-white px-3 py-2.5 text-sm focus:border-brand-accent focus:outline-none focus:ring-2 focus:ring-brand-accent/30"
              >
                <option value="">Selecciona un modelo</option>
                <option>Actros</option>
                <option>Axor</option>
                <option>Atego</option>
                <option>Accelo</option>
                <option>Arocs</option>
                <option>Atron</option>
                <option>Otro</option>
              </select>
            </div>

            <div class="sm:col-span-2">
              <label for="mensaje" class="block text-sm font-semibold text-brand-dark">¿Cómo podemos ayudarte?</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                required
                placeholder="Describe brevemente el problema o servicio que necesitas."
                class="mt-2 w-full rounded-md border border-brand-dark/15 bg-white px-3 py-2.5 text-sm focus:border-brand-accent focus:outline-none focus:ring-2 focus:ring-brand-accent/30"
              ></textarea>
            </div>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-3">
            <button type="submit" class="btn-primary">
              <i class="pi pi-send" aria-hidden="true"></i>
              Enviar mensaje
            </button>
            <a href={whatsappLink()} target="_blank" rel="noopener" class="btn-wtz">
              <i class="pi pi-whatsapp" aria-hidden="true"></i>
              Mejor por WhatsApp
            </a>
            <p class="text-xs text-brand-dark/60">Tiempo de respuesta promedio: menos de 1 hora hábil.</p>
          </div>

          <div
            id="formSuccess"
            class="mt-5 hidden rounded-md border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-800"
            role="status"
          >
            <p class="font-semibold">¡Gracias! Recibimos tu mensaje.</p>
            <p class="mt-1">Te contactaremos a la brevedad. Si es urgente, escríbenos por WhatsApp.</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const ok = document.getElementById('formSuccess');
  if (form && ok) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      ok.classList.remove('hidden');
      form.reset();
      ok.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(() => ok.classList.add('hidden'), 6000);
    });
  }
</script>
