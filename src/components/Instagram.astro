---
import { site } from '../config/site';

const posts = [
  {
    id: 1,
    image: 'https://placehold.co/600x600/0B1E3F/ffffff/png?text=Actros+en+taller&font=inter',
    caption: 'Mantención completa de un Actros 2645 listo para volver a la ruta. 💪',
    likes: 248,
    comments: 18,
  },
  {
    id: 2,
    image: 'https://placehold.co/600x600/061331/ffffff/png?text=Diagnostico+Xentry&font=inter',
    caption: 'Diagnóstico electrónico con Xentry. Detectar a tiempo evita paradas largas.',
    likes: 312,
    comments: 24,
  },
  {
    id: 3,
    image: 'https://placehold.co/600x600/1E3A8A/ffffff/png?text=Atego+listo&font=inter',
    caption: 'Atego 1726 entregado tras servicio de embrague y caja. Cliente feliz. 🚚',
    likes: 187,
    comments: 12,
  },
  {
    id: 4,
    image: 'https://placehold.co/600x600/3B5BA8/ffffff/png?text=Repuestos+OEM&font=inter',
    caption: 'Solo trabajamos con repuestos Mercedes-Benz originales. Trazabilidad y garantía.',
    likes: 421,
    comments: 36,
  },
  {
    id: 5,
    image: 'https://placehold.co/600x600/0B1E3F/ffffff/png?text=Servicio+en+ruta&font=inter',
    caption: 'Asistencia en ruta a las 03:00 AM. Camión operando antes del amanecer. 🌙',
    likes: 564,
    comments: 48,
  },
  {
    id: 6,
    image: 'https://placehold.co/600x600/C8102E/ffffff/png?text=Equipo+Red+Truck&font=inter',
    caption: 'El equipo Red Truck: técnicos certificados y apasionados por los camiones.',
    likes: 612,
    comments: 52,
  },
];
---

<section id="instagram" class="section bg-white">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="eyebrow">Instagram</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-brand-dark">
          Mira nuestro trabajo en {site.social.instagramHandle}
        </h2>
        <p class="mt-4 text-brand-dark/70">
          Reparaciones, mantenciones y atención en ruta. Síguenos para ver el día a día del taller.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <a
          href={site.social.instagram}
          target="_blank"
          rel="noopener"
          class="btn-ghost"
        >
          <i class="pi pi-instagram" aria-hidden="true"></i>
          Seguir
        </a>
        <div class="inline-flex rounded-md border border-brand-dark/15">
          <button
            type="button"
            data-carousel-prev
            class="h-11 w-11 inline-flex items-center justify-center text-brand-dark hover:bg-brand-dark/5 disabled:opacity-40"
            aria-label="Anterior"
          >
            <i class="pi pi-arrow-left" aria-hidden="true"></i>
          </button>
          <button
            type="button"
            data-carousel-next
            class="h-11 w-11 inline-flex items-center justify-center text-brand-dark hover:bg-brand-dark/5 border-l border-brand-dark/15 disabled:opacity-40"
            aria-label="Siguiente"
          >
            <i class="pi pi-arrow-right" aria-hidden="true"></i>
          </button>
        </div>
      </div>
    </div>

    <div class="relative mt-10">
      <div
        data-carousel-track
        class="no-scrollbar flex gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2"
      >
        {posts.map((p) => (
          <article
            class="snap-start shrink-0 w-[280px] sm:w-[320px] rounded-xl overflow-hidden border border-brand-dark/10 bg-white hover:shadow-soft transition"
            data-carousel-item
          >
            <a href={site.social.instagram} target="_blank" rel="noopener" class="block group">
              <div class="aspect-square overflow-hidden bg-brand-dark/5">
                <img
                  src={p.image}
                  alt={p.caption}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-4">
                <p class="text-sm text-brand-dark line-clamp-2">{p.caption}</p>
                <div class="mt-3 flex items-center gap-4 text-xs text-brand-dark/60">
                  <span class="inline-flex items-center gap-1.5">
                    <i class="pi pi-heart-fill text-brand-red" aria-hidden="true"></i>
                    {p.likes}
                  </span>
                  <span class="inline-flex items-center gap-1.5">
                    <i class="pi pi-comment" aria-hidden="true"></i>
                    {p.comments}
                  </span>
                  <span class="ml-auto inline-flex items-center gap-1 text-brand-accent font-semibold">
                    Ver post
                    <i class="pi pi-external-link" aria-hidden="true"></i>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.querySelector<HTMLElement>('[data-carousel-track]');
  const prev = document.querySelector<HTMLButtonElement>('[data-carousel-prev]');
  const next = document.querySelector<HTMLButtonElement>('[data-carousel-next]');

  if (track && prev && next) {
    const step = () => {
      const item = track.querySelector<HTMLElement>('[data-carousel-item]');
      const gap = parseInt(getComputedStyle(track).columnGap || '20', 10);
      return (item?.offsetWidth ?? 300) + gap;
    };

    const update = () => {
      const max = track.scrollWidth - track.clientWidth - 1;
      prev.disabled = track.scrollLeft <= 0;
      next.disabled = track.scrollLeft >= max;
    };

    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }
</script>
