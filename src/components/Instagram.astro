---
import { Image } from 'astro:assets';
import { site } from '../config/site';
import post1 from '../assets/instagram/post-1.webp';
import post2 from '../assets/instagram/post-2.webp';
import post3 from '../assets/instagram/post-3.webp';
import post4 from '../assets/instagram/post-4.webp';
import post5 from '../assets/instagram/post-5.webp';
import post6 from '../assets/instagram/post-6.webp';

const posts = [
  {
    id: 1,
    image: post1,
    caption: 'Camión pesado en mantención, listo para volver a trabajar con seguridad.',
    likes: 248,
    comments: 18,
  },
  {
    id: 2,
    image: post2,
    caption: 'Scanner y diagnóstico electrónico para detectar fallas antes de cambiar piezas innecesarias.',
    likes: 312,
    comments: 24,
  },
  {
    id: 3,
    image: post3,
    caption: 'Revisión de embrague y caja en camión de trabajo, con diagnóstico paso a paso.',
    likes: 187,
    comments: 12,
  },
  {
    id: 4,
    image: post4,
    caption: 'Selección de repuestos y componentes según disponibilidad, compatibilidad y necesidad del equipo.',
    likes: 421,
    comments: 36,
  },
  {
    id: 5,
    image: post5,
    caption: 'Grúas y coordinación de traslado cuando un camión o maquinaria necesita moverse.',
    likes: 564,
    comments: 48,
  },
  {
    id: 6,
    image: post6,
    caption: 'Red Truck: especialidad Mercedes-Benz, trabajo multimarca y trato directo con el dueño del camión.',
    likes: 612,
    comments: 52,
  },
];
---

<section id="instagram" class="section bg-transparent text-white">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="eyebrow">Instagram</p>
        <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-[1.05]">
          Mira el trabajo del taller en
          <span class="text-brand-red">{site.social.instagramHandle}</span>
        </h2>
        <p class="mt-5 text-white/65 leading-relaxed">
          Reparaciones, mantenciones, scanner, electrónica diésel y trabajos reales en camiones
          pesados y semi pesados. Síguenos para ver el día a día del taller.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <a
          href={site.social.instagram}
          target="_blank"
          rel="noopener"
          class="btn-ghost"
        >
          <i class="pi pi-instagram" aria-hidden="true"></i>
          Seguir en Instagram
        </a>
      </div>
    </div>

    <div class="relative mt-10 marquee-mask">
      <div class="marquee flex w-max gap-5">
        {[...posts, ...posts].map((p, idx) => (
          <article
            class="shrink-0 w-[280px] sm:w-[320px] rounded-xl overflow-hidden border border-white/10 bg-black/60 shadow-soft backdrop-blur-sm hover:border-brand-red/40 transition-all duration-300"
            aria-hidden={idx >= posts.length ? 'true' : undefined}
          >
            <a href={site.social.instagram} target="_blank" rel="noopener" class="block group">
              <div class="aspect-square overflow-hidden bg-black relative">
                <Image
                  src={p.image}
                  alt={p.caption}
                  widths={[280, 400]}
                  sizes="320px"
                  formats={['avif', 'webp']}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
              <div class="p-4">
                <p class="text-sm text-white/85 line-clamp-2">{p.caption}</p>
                <div class="mt-3 flex items-center gap-4 text-xs text-white/55">
                  <span class="inline-flex items-center gap-1.5">
                    <i class="pi pi-heart-fill text-brand-red" aria-hidden="true"></i>
                    {p.likes}
                  </span>
                  <span class="inline-flex items-center gap-1.5">
                    <i class="pi pi-comment" aria-hidden="true"></i>
                    {p.comments}
                  </span>
                  <span class="ml-auto inline-flex items-center gap-1 text-brand-red font-semibold">
                    Ver post
                    <i class="pi pi-external-link" aria-hidden="true"></i>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .marquee {
    animation: marquee-scroll 60s linear infinite;
    will-change: transform;
  }
  .marquee:hover {
    animation-play-state: paused;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-50% - 10px)); }
  }
  .marquee-mask {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
    mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee { animation: none; }
  }
</style>
