---
import { site } from '../config/site';

const posts = [
  {
    id: 1,
    image: 'https://placehold.co/600x600/0B1E3F/ffffff/png?text=Actros+en+taller&font=inter',
    caption: 'Actros en mantención, listo para volver a trabajar con seguridad.',
    likes: 248,
    comments: 18,
  },
  {
    id: 2,
    image: 'https://placehold.co/600x600/061331/ffffff/png?text=Diagnostico+Xentry&font=inter',
    caption: 'Diagnóstico electrónico para detectar fallas antes de cambiar piezas innecesarias.',
    likes: 312,
    comments: 24,
  },
  {
    id: 3,
    image: 'https://placehold.co/600x600/1E3A8A/ffffff/png?text=Atego+listo&font=inter',
    caption: 'Atego revisado por embrague y caja, con trabajo coordinado paso a paso.',
    likes: 187,
    comments: 12,
  },
  {
    id: 4,
    image: 'https://placehold.co/600x600/3B5BA8/ffffff/png?text=Repuestos+OEM&font=inter',
    caption: 'Selección de repuestos y componentes según disponibilidad, compatibilidad y necesidad del camión.',
    likes: 421,
    comments: 36,
  },
  {
    id: 5,
    image: 'https://placehold.co/600x600/0B1E3F/ffffff/png?text=Servicio+en+ruta&font=inter',
    caption: 'Cuando un camión se detiene, el diagnóstico correcto ahorra tiempo y evita gastos demás.',
    likes: 564,
    comments: 48,
  },
  {
    id: 6,
    image: 'https://placehold.co/600x600/C8102E/ffffff/png?text=Equipo+Red+Truck&font=inter',
    caption: 'Red Truck: experiencia Mercedes-Benz, trabajo serio y trato directo con el dueño del camión.',
    likes: 612,
    comments: 52,
  },
];
---

<section id="instagram" class="section bg-transparent text-white">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="eyebrow">Instagram</p>
        <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-[1.05]">
          Mira el trabajo del taller en
          <span class="text-brand-red">{site.social.instagramHandle}</span>
        </h2>
        <p class="mt-5 text-white/65 leading-relaxed">
          Reparaciones, mantenciones, diagnósticos y trabajos reales en camiones Mercedes-Benz.
          Síguenos para ver el día a día del taller.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <a
          href={site.social.instagram}
          target="_blank"
          rel="noopener"
          class="btn-ghost"
        >
          <i class="pi pi-instagram" aria-hidden="true"></i>
          Seguir en Instagram
        </a>
        <div class="inline-flex rounded-md border border-white/15 overflow-hidden">
          <button
            type="button"
            data-carousel-prev
            class="h-11 w-11 inline-flex items-center justify-center text-white hover:bg-brand-red/20 disabled:opacity-30 transition-colors"
            aria-label="Anterior"
          >
            <i class="pi pi-arrow-left" aria-hidden="true"></i>
          </button>
          <button
            type="button"
            data-carousel-next
            class="h-11 w-11 inline-flex items-center justify-center text-white hover:bg-brand-red/20 border-l border-white/15 disabled:opacity-30 transition-colors"
            aria-label="Siguiente"
          >
            <i class="pi pi-arrow-right" aria-hidden="true"></i>
          </button>
        </div>
      </div>
    </div>

    <div class="relative mt-10">
      <div
        data-carousel-track
        class="no-scrollbar flex gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2"
      >
        {posts.map((p) => (
          <article
            class="snap-start shrink-0 w-[280px] sm:w-[320px] rounded-xl overflow-hidden border border-white/10 bg-black/60 shadow-soft backdrop-blur-sm hover:border-brand-red/40 transition-all duration-300"
            data-carousel-item
          >
            <a href={site.social.instagram} target="_blank" rel="noopener" class="block group">
              <div class="aspect-square overflow-hidden bg-black relative">
                <img
                  src={p.image}
                  alt={p.caption}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
              <div class="p-4">
                <p class="text-sm text-white/85 line-clamp-2">{p.caption}</p>
                <div class="mt-3 flex items-center gap-4 text-xs text-white/55">
                  <span class="inline-flex items-center gap-1.5">
                    <i class="pi pi-heart-fill text-brand-red" aria-hidden="true"></i>
                    {p.likes}
                  </span>
                  <span class="inline-flex items-center gap-1.5">
                    <i class="pi pi-comment" aria-hidden="true"></i>
                    {p.comments}
                  </span>
                  <span class="ml-auto inline-flex items-center gap-1 text-brand-red font-semibold">
                    Ver post
                    <i class="pi pi-external-link" aria-hidden="true"></i>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.querySelector<HTMLElement>('[data-carousel-track]');
  const prev = document.querySelector<HTMLButtonElement>('[data-carousel-prev]');
  const next = document.querySelector<HTMLButtonElement>('[data-carousel-next]');

  if (track && prev && next) {
    const step = () => {
      const item = track.querySelector<HTMLElement>('[data-carousel-item]');
      const gap = parseInt(getComputedStyle(track).columnGap || '20', 10);
      return (item?.offsetWidth ?? 300) + gap;
    };

    const update = () => {
      const max = track.scrollWidth - track.clientWidth - 1;
      prev.disabled = track.scrollLeft <= 0;
      next.disabled = track.scrollLeft >= max;
    };

    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }
</script>
