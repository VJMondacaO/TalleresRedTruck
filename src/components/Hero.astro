---
import { Image } from 'astro:assets';
import { site, whatsappLink } from '../config/site';
import heroImage from '../assets/hero.png';
---

<section id="top" class="relative overflow-hidden bg-black text-white">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <Image
      src={heroImage}
      alt=""
      class="h-full w-full object-contain opacity-70 scale-[1.75] lg:scale-90"
      style="object-position: center;"
      widths={[640, 960, 1280, 1920]}
      sizes="(max-width: 768px) 100vw, 80vw"
      formats={['avif', 'webp']}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-l from-black via-black/70 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black"></div>
    <div class="absolute -top-32 -right-32 h-[420px] w-[420px] rounded-full bg-radial-red blur-2xl"></div>
    <div
      class="absolute inset-0 bg-grid-faint"
      style="background-size: 56px 56px;"
    ></div>

  </div>

  <div class="container-x relative grid min-h-[92vh] items-center gap-12 py-24 lg:grid-cols-12">
    <div class="lg:col-span-7 lg:col-start-6 text-right lg:ml-auto">
      <h1 class="text-4xl font-extrabold leading-[1.02] sm:text-5xl lg:text-7xl">
        Taller de camiones pesados
        <span class="block text-brand-red">y semi pesados.</span>
        <span class="block text-white/95">En San Rafael.</span>
      </h1>

      <p class="mt-6 max-w-2xl ml-auto text-lg text-white/70 leading-relaxed">
        Especialistas en Mercedes-Benz y atención multimarca para Volvo, Scania, americanos y
        chinos. Scanner, electrónica diésel, reparación, grúas para camiones y transporte de
        maquinaria.
      </p>

      <div class="mt-10 flex flex-wrap gap-3 justify-end">
        <a href={whatsappLink()} target="_blank" rel="noopener" class="btn-wtz">
          <i class="pi pi-whatsapp" aria-hidden="true"></i>
          Coordinar por WhatsApp
        </a>
        <a href="#servicios" class="btn-ghost">
          Ver servicios
          <i class="pi pi-arrow-down text-xs" aria-hidden="true"></i>
        </a>
      </div>

    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2 text-white/40 text-xs">
    <span class="uppercase tracking-[0.3em]">Desliza</span>
    <span class="h-10 w-px bg-gradient-to-b from-brand-red to-transparent"></span>
  </div>
</section>
